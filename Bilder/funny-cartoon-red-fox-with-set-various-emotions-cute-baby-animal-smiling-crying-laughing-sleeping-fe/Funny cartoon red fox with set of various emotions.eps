   <dc:title>
    <rdf:Alt>
     <rdf:li xml:lang="x-default">Funny cartoon red fox with set of various emotions</rdf:li>
    </rdf:Alt>
   </dc:title>
   <dc:description>
    <rdf:Alt>
     <rdf:li xml:lang="x-default">Funny cartoon red fox with set of various emotions. Cute baby animal smiling, crying, laughing, sleeping, feeling happy, angry, sad. Vector illustration for mobile app, sticker, kids print design</rdf:li>
    </rdf:Alt>
   </dc:description>
